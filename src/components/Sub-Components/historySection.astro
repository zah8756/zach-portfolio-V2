---
interface Props {
  href: string;
  imgSrc: string;
  imgAlt: string;
  startDate: string;
  endDate: string;
  place: string;
  role: string;
  bulletPoints: string[];
}

const { href, imgSrc, imgAlt, startDate, endDate, place, role, bulletPoints } = Astro.props;
---

<li class="eduObject">
  <a class="eduTarget" href={href}>
    <span class="eduImgWraper">
      <img class="eduImg" src={imgSrc} alt={imgAlt} />
    </span>
  </a>
  <div class="eduInfo">
    <div class="eduDate">
      <span>{startDate}</span>
      <span>-</span>
      <span>{endDate}</span>
    </div>
    <h3>{place}</h3>
    <p class="eduTitle">{role}</p>
    <ul class="bulletList">
      {bulletPoints.map((point) => <li class="bulletItem">{point}</li>)}
    </ul>
  </div>
</li>

<style>
  .eduObject {
    position: relative;
    padding-top: 1rem;
    padding-bottom: 1rem;
    margin-left: 1.5rem;
  }

  .eduTarget {
    position: absolute;
    display: flex;
    width: 3rem;
    height: 3rem;
    background: var(--clr-light);
    border-radius: 9999px;
    left: -4rem;
    top: 2rem;
  }

  .eduImgWraper {
    overflow: hidden;
  }

  .eduImg {
    object-fit: contain;
    width: 100%;
    height: 100%;
    aspect-ratio: 1/1;
  }

  .eduInfo {
    gap: 0.25rem;
    display: flex;
    justify-content: start;
    flex-direction: column;
  }

  .eduInfo h3 {
    padding-right: 1.5rem;
  }

  .bulletList {
    padding-left: 1.25rem;
    margin: 0;
  }

  .bulletItem {
    padding-right: 2.5rem;
    line-height: 1.75rem;
    margin: 10px 0;
  }

  .eduTitle {
    color: #b2b4adc4;
    margin: 0;
    font-family: var(--ff-secondary);
  }

  .eduDate {
    color: #b2b4adc4;
    margin: 0;
    font-family: var(--ff-secondary);
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  @media screen and (max-width: 600px) {
    .eduObject {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-left: 0;
      padding: 1rem;
      gap: 0.6rem;
    }

    .eduTarget {
      position: static;
      width: 2.5rem;
      height: 2.5rem;
      flex-shrink: 0;
    }

    .eduInfo {
      width: 100%;
      align-items: center;
      text-align: center;
    }

    .eduInfo h3 {
      padding-right: 0;
      font-size: 1rem;
    }

    .eduDate {
      justify-content: center;
    }

    .bulletList {
      
      padding-left: 1rem;
      margin-top: 0.5rem;
      text-align: left;
      width: 100%;
    }

    .bulletItem {
      padding-right: 0;
      line-height: 1.6rem;
      margin: 0;
      font-size: 0.9rem;
      padding-top: 0.6rem;
      padding-bottom: 0.6rem;
      border-top: 1px solid #3d3f3a55;
    }

    .bulletItem:first-child {
      border-top: none;
      padding-top: 0.25rem;
    }

    .eduDate {
      font-size: 0.8rem;
    }

    .eduTitle {
      font-size: 0.85rem;
    }
  }
</style>
