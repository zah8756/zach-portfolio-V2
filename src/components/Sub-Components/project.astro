---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Tech {
  label: string;
  colorClass: string;
}

interface Props {
  href: string;
  imgSrc: ImageMetadata;
  imgAlt: string;
  name: string;
  nameClass?: string;
  techs: Tech[];
}

const { href, imgSrc, imgAlt, name, nameClass = "", techs } = Astro.props;
---

<a href={href} class="portfolioItem">
  <div class="projectContainer">
    <div class="techContainer">
      <p class={`itemName ${nameClass}`}>{name}</p>
      <div class="techItems">
        {techs.map((tech) => (
          <p class={`tech ${tech.colorClass}`}>{tech.label}</p>
        ))}
      </div>
    </div>
    <Image src={imgSrc} alt={imgAlt} class="portfolioImg" />
  </div>
</a>

<style>
  .portfolioItem {
    background: var(--clr-accent);
    margin: 0 auto;
    overflow: hidden;
    position: relative;
    text-decoration: none;
    border-radius: 15px;
  }

  .portfolioItem:focus {
    position: relative;
    z-index: 2;
  }

  .projectContainer {
    position: relative;
    overflow: hidden;
  }

  .portfolioImg {
    display: block;
    width: 100%;
    height: 480px;
    object-fit: cover;
    object-position: top;
    transition:
      transform 750ms cubic-bezier(0.5, 0, 0.5, 1),
      opacity 250ms linear;
  }

  .portfolioItem:hover .portfolioImg,
  .portfolioItem:focus .portfolioImg {
    transform: scale(1.2);
    opacity: 0.25;
  }

  .techContainer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    visibility: hidden;
    opacity: 0;
    transition:
      opacity 250ms linear,
      visibility 250ms;
  }

  .portfolioItem:hover .techContainer,
  .portfolioItem:focus .techContainer {
    visibility: visible;
    opacity: 1;
  }

  .itemName {
    text-transform: uppercase;
    color: white;
    display: inline-block;
    margin: 0;
    font-size: var(--fs-itemName);
    font-weight: bold;
  }

  .itemName::after {
    content: "";
    display: block;
    height: 3px;
    margin-bottom: 0.2em;
    background: var(--clr-light);
  }

  .rockPaper {
    width: min-content;
  }

  .techItems {
    display: flex;
    gap: 0.3em 0.2em;
    flex-wrap: wrap;
    justify-content: center;
    padding: 0 1rem;
  }

  .tech {
    padding: 0.2em 1em;
    border: 3px solid var(--tech-color, black);
    border-radius: 900px;
    margin: 0;
    color: white;
    font-size: 0.8em;
    transition:
      background-color 250ms linear,
      color 250ms linear;
  }

  .tech:hover {
    background-color: var(--tech-color, white);
    color: black;
  }

  /* Tech color classes — single property drives both border and hover bg */
  .javaColor    { --tech-color: var(--clr-js); }
  .figmaColor   { --tech-color: var(--clr-figma); }
  .angularColor { --tech-color: var(--clr-angular); }
  .reactColor   { --tech-color: var(--clr-react); }
  .mongoColor   { --tech-color: var(--clr-MongoDB); }
  .swiftColor   { --tech-color: var(--clr-swift); }
  .phpColor     { --tech-color: var(--clr-php); }
  .astroColor   { --tech-color: var(--clr-astro); }
  .typescriptColor { --tech-color: var(--clr-typescript); }
  .tailwindColor { --tech-color: var(--clr-tailwind); }
</style>
