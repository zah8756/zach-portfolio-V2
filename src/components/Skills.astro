---

<section class="mySkills" id="skills">
  <h2 class="sectionTitle" id="sectionSkills">Current Skill Set</h2>
  <div id="allSkills">
    <div id="skillWraper">
      {skills.map((skill) => <Skill {...skill} />)}
    </div>
  </div>
</section>

<style>
  .mySkills {
    color: var(--clr-light);
    text-align: center;
  }

  #sectionSkills {
    text-align: center;
    color: var(--clr-lightText);
  }

  #sectionSkills::after {
    content: "";
    display: block;
    width: 2em;
    height: 1px;
    margin: 0.5em auto 1rem;
    background: var(--clr-light);
    opacity: 0.5;
  }

  #skillWraper {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
    margin-top: 2em;
  }
</style>
