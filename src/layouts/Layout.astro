---
const { title } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@600;700;800;900&display=swap" rel="stylesheet">
		<script src="https://kit.fontawesome.com/66a50df515.js" crossorigin="anonymous"></script>
		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<header>

			<input type="checkbox" id="check">
			<label for="check" class="icons">
				<i class="fa-solid fa-bars" id="menu-icon"></i>
				<i class="fa-solid fa-x" id="close-icon"></i>
			</label>
	
			<nav id="nav">
				<ul id="navList">
					<li class="navItem"><a href="/#home" class="navLink">Home</a></li>
					<li class="navItem"><a href="/#skills" class="navLink">Skills</a></li>
					<li class="navItem"><a href="/#history" class="navLink">History</a></li>
					<li class="navItem"><a href="/#projects" class="navLink">Projects</a></li>
				</ul>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer id="footerSection">
			<div class="spacer">
				<div class="footSpace">
					<p id="footDate">&#169; 2026</p>
					<a href="#" id="footerLink">zachh.dev</a>
				</div>
				<ul class="socialList">
					<li class="socialListItem"><a class="socialListLink" href="https://github.com/zah8756" aria-label="GitHub"><i class="fa-brands fa-github"></i></a></li>
					<li class="socialListItem"><a class="socialListLink" href="mailto:320zach@gmail.com" aria-label="Email"><i class="fa-solid fa-envelope"></i></a></li>
					<li class="socialListItem"><a class="socialListLink" href="https://www.linkedin.com/in/zachary-harwood-4a5586299/" aria-label="LinkedIn"><i class="fa-brands fa-linkedin"></i></a></li>
				</ul>
			</div>
		</footer>
	</body>
</html>

<script>
  const navToggle = document.querySelector<HTMLInputElement>('#check');
  const navLinks = document.querySelectorAll('.navLink');

  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      if (navToggle) navToggle.checked = false;
    });
  });
</script>

<style is:global>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>
